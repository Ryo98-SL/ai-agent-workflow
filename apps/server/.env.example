# Server environment (apps/server)
# Copy to apps/server/.env. Prisma CLI auto-loads this file; the dev server
# loads it via `tsx --env-file=.env`.

# Postgres connection. Matches docker-compose.yml defaults for local dev.
# Knowledge Base retrieval requires the pgvector extension (e.g. Railway
# Postgres); the migration runs `CREATE EXTENSION IF NOT EXISTS vector`.
DATABASE_URL="postgresql://workflow:workflow@127.0.0.1:5432/workflow?schema=public"

# AES-256-GCM master key for encrypting provider API keys at rest.
# Generate with: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=""

# Better Auth signing secret.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Public base URL of the auth/api server (used by Better Auth for callbacks).
BETTER_AUTH_URL="http://127.0.0.1:8788"

# Google OAuth (optional — leave empty to disable the Google sign-in button).
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Outbound HTTP(S) proxy for server-side fetch (e.g. when oauth2.googleapis.com
# is unreachable directly). Node's global fetch does not read HTTPS_PROXY
# automatically — set this to route all outbound requests through a proxy.
# Example: http://127.0.0.1:7890
OUTBOUND_PROXY_URL=""

# Comma-separated hosts that bypass the proxy. Local model servers (Ollama),
# the DB, and LAN hosts must be here. Defaults to localhost,127.0.0.1,::1,0.0.0.0.
# Add your own, e.g. ".internal,192.168.1.50" for a LAN Ollama.
NO_PROXY=""

# Platform-funded provider keys backing "AI credits" runs. On first use the
# server encrypts the configured key into platform_provider_key and then reads
# from DB. MVP credits only enable DeepSeek; other providers are reserved.
# The base URL is forced server-side; override only if you proxy a provider.
CREDITS_DEEPSEEK_API_KEY=""
CREDITS_OPENAI_API_KEY=""
CREDITS_ANTHROPIC_API_KEY=""
# CREDITS_DEEPSEEK_BASE_URL="https://api.deepseek.com"
# CREDITS_OPENAI_BASE_URL="https://api.openai.com/v1"
# CREDITS_ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"

# Platform-managed embedding model for Knowledge Base indexing. If
# EMBEDDING_API_KEY is empty, the server falls back to CREDITS_OPENAI_API_KEY
# when present. The MVP supports platform-managed embeddings only; user-managed
# embedding providers are reserved in the API but not enabled in the UI.
EMBEDDING_PROVIDER="openai"
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_BASE_URL="https://api.openai.com/v1"
EMBEDDING_API_KEY=""
KNOWLEDGE_INDEXER_CONCURRENCY="1"

# Email tool (optional). The Email node defaults to dry-run (compose only, no
# send). To enable real sending, set both: a Resend API key and a verified
# "from" address. When unset, "Send for real" errors and dry-run stays default.
RESEND_API_KEY=""
EMAIL_FROM=""

# Frontend origin allowed by CORS (credentials: true). In production set this to
# the deployed web origin, e.g. https://app.example.com
FRONTEND_ORIGIN="http://127.0.0.1:5173"

# Cookie domain shared by frontend + api (e.g. .example.com). Leave empty for
# local dev where both are on 127.0.0.1.
COOKIE_DOMAIN=""

PORT="8788"

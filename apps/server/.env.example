# Server environment (apps/server)
# Copy to apps/server/.env. Prisma CLI auto-loads this file; the dev server
# loads it via `tsx --env-file=.env`.

# Postgres connection. Matches docker-compose.yml defaults for local dev.
DATABASE_URL="postgresql://workflow:workflow@127.0.0.1:5432/workflow?schema=public"

# AES-256-GCM master key for encrypting provider API keys at rest.
# Generate with: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=""

# Better Auth signing secret.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Public base URL of the auth/api server (used by Better Auth for callbacks).
BETTER_AUTH_URL="http://127.0.0.1:8788"

# Google OAuth (optional — leave empty to disable the Google sign-in button).
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Outbound HTTP(S) proxy for server-side fetch (e.g. when oauth2.googleapis.com
# is unreachable directly). Node's global fetch does not read HTTPS_PROXY
# automatically — set this to route all outbound requests through a proxy.
# Example: http://127.0.0.1:7890
OUTBOUND_PROXY_URL=""

# Comma-separated hosts that bypass the proxy. Local model servers (Ollama),
# the DB, and LAN hosts must be here. Defaults to localhost,127.0.0.1,::1,0.0.0.0.
# Add your own, e.g. ".internal,192.168.1.50" for a LAN Ollama.
NO_PROXY=""

# Frontend origin allowed by CORS (credentials: true). In production set this to
# the deployed web origin, e.g. https://app.example.com
FRONTEND_ORIGIN="http://127.0.0.1:5173"

# Cookie domain shared by frontend + api (e.g. .example.com). Leave empty for
# local dev where both are on 127.0.0.1.
COOKIE_DOMAIN=""

PORT="8788"

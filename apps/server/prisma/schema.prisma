// Prisma schema for the AI Agent Workflow server.
//
// Single Postgres database shared by Better Auth (user/session/account/
// verification) and the application tables. LangGraph checkpoint tables are NOT
// modelled here — they are owned by PostgresSaver.setup() at runtime.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Better Auth managed tables
// ---------------------------------------------------------------------------

model User {
  id            String   @id
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions     Session[]
  accounts     Account[]
  providerKeys ProviderKey[]
  customModels CustomModel[]
  workflows    Workflow[]
  runs         Run[]
  creditGrant  CreditGrant?
  knowledgeBases KnowledgeBase[]

  @@map("user")
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ---------------------------------------------------------------------------
// Application tables
// ---------------------------------------------------------------------------

model ProviderKey {
  id         String   @id @default(cuid())
  userId     String
  provider   String
  label      String
  ciphertext Bytes
  iv         Bytes
  authTag    Bytes
  last4      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, label])
  @@map("provider_key")
}

model CustomModel {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  model     String
  baseURL   String?
  label     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, model])
  @@map("custom_model")
}

model CreditGrant {
  id            String   @id @default(cuid())
  userId        String   @unique
  status        String   @default("approved")
  grantedTokens Int
  balanceTokens Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_grant")
}

model PlatformProviderKey {
  id         String   @id @default(cuid())
  provider   String   @unique
  baseURL    String
  enabled    Boolean  @default(true)
  ciphertext Bytes
  iv         Bytes
  authTag    Bytes
  last4      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("platform_provider_key")
}

model Workflow {
  id        String   @id @default(cuid())
  userId    String
  name      String
  document  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs      Run[]

  @@index([userId])
  @@map("workflow")
}

model Run {
  id          String     @id
  userId      String
  // Nullable: a run may execute an inline/unsaved workflow with no stored row.
  workflowId  String?
  status      String
  input       Json
  output      Json?
  error       Json?
  createdAt   DateTime   @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow    Workflow?  @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  events      RunEvent[]

  @@index([userId])
  @@index([workflowId])
  @@map("run")
}

model RunEvent {
  id        String   @id @default(cuid())
  runId     String
  sequence  Int
  type      String
  message   String
  payload   Json?
  createdAt DateTime @default(now())
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, sequence])
  @@map("run_event")
}

model KnowledgeBase {
  id          String              @id @default(cuid())
  userId      String?
  name        String
  description String?
  visibility  String              @default("private")
  settings    Json
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   KnowledgeDocument[]
  chunks      KnowledgeChunk[]

  @@index([userId])
  @@index([visibility])
  @@map("knowledge_base")
}

model KnowledgeDocument {
  id              String           @id @default(cuid())
  knowledgeBaseId String
  title           String
  sourceType      String
  filename        String?
  mimeType        String?
  parser          Json?
  characterCount  Int
  rawText         String?
  status          String           @default("queued")
  errorMessage    String?
  retryCount      Int              @default(0)
  lockedAt        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  knowledgeBase   KnowledgeBase    @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks          KnowledgeChunk[]

  @@index([knowledgeBaseId])
  @@index([status])
  @@map("knowledge_document")
}

model KnowledgeChunk {
  id                  String            @id @default(cuid())
  knowledgeBaseId     String
  knowledgeDocumentId String
  ordinal             Int
  content             String
  title               String
  url                 String?
  icon                String?
  metadata            Json?
  embedding           Unsupported("vector")?
  createdAt           DateTime          @default(now())
  knowledgeBase       KnowledgeBase     @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  knowledgeDocument   KnowledgeDocument @relation(fields: [knowledgeDocumentId], references: [id], onDelete: Cascade)

  @@unique([knowledgeDocumentId, ordinal])
  @@index([knowledgeBaseId])
  @@index([knowledgeDocumentId])
  @@map("knowledge_chunk")
}

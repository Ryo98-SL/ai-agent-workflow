{
  "name": "ai-agent-workflow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "description": "Web-first workflow workbench monorepo for AI agent workflow debugging.",
  "scripts": {
    "dev": "turbo run @ai-agent-workflow/web#dev",
    "dev:desktop": "pnpm --filter @ai-agent-workflow/desktop dev",
    "dev:server": "pnpm --filter @ai-agent-workflow/server dev",
    "dev:web": "pnpm --filter @ai-agent-workflow/web dev",
    "start": "pnpm dev",
    "build": "pnpm build:workspaces",
    "build:workspaces": "turbo run build",
    "lint": "pnpm lint:legacy-runtime && pnpm lint:workspaces",
    "lint:legacy-runtime": "eslint src/domain tests/domain tests/setup.ts eslint.config.js",
    "lint:workspaces": "turbo run lint",
    "typecheck": "pnpm typecheck:legacy-runtime && pnpm typecheck:workspaces",
    "typecheck:legacy-runtime": "tsc -p tsconfig.json --noEmit",
    "typecheck:workspaces": "turbo run typecheck",
    "test": "pnpm test:legacy-runtime && pnpm test:workspaces",
    "test:legacy-runtime": "vitest run tests/domain",
    "test:workspaces": "turbo run test",
    "test:watch": "vitest",
    "smoke": "pnpm --filter @ai-agent-workflow/workbench-ui test"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.42"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@ai-agent-workflow/workflow-domain": "workspace:*",
    "@eslint/js": "^9.28.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^22.15.29",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.3",
    "turbo": "^2.6.1",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
